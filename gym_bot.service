[Unit]
Description=Gym Auto-Registration Bot
After=network.target

[Service]
Type=simple
User=YOUR_USERNAME
WorkingDirectory=/home/YOUR_USERNAME/gym_bot
ExecStart=/usr/bin/python3 /home/YOUR_USERNAME/gym_bot/bot.py
Restart=always
RestartSec=10
StandardOutput=append:/home/YOUR_USERNAME/gym_bot/bot.log
StandardError=append:/home/YOUR_USERNAME/gym_bot/bot.log

[Install]
WantedBy=multi-user.target
